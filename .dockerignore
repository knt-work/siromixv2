# ============================================================
# SiroMix V2 - Docker .dockerignore
# ============================================================
# Generated: 2026-02-22
# Excludes unnecessary files from Docker build context

# ============================================================
# Version Control
# ============================================================
.git/
.gitignore
.gitattributes

# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
.venv/
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.hypothesis/

# ============================================================
# Node.js
# ============================================================
node_modules/
npm-debug.log*
yarn-debug.log*
.next/
out/
build/
dist/
coverage/

# ============================================================
# Environment & Secrets
# ============================================================
.env
.env.local
.env.*.local
!.env.example

# ============================================================
# IDE / Editor
# ============================================================
.vscode/
.idea/
*.swp
*.swo
*~

# ============================================================
# OS
# ============================================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================================
# Documentation & Specs
# ============================================================
README.md
docs/
specs/
.specify/

# ============================================================
# Logs
# ============================================================
*.log
*.log.*
logs/

# ============================================================
# Testing
# ============================================================
.pytest_cache/
.vitest/
coverage/
*.test.ts
*.spec.ts
tests/
__tests__/

# ============================================================
# Docker
# ============================================================
Dockerfile
docker-compose.yml
docker-compose*.yml
.dockerignore

# ============================================================
# CI/CD
# ============================================================
.github/

# ============================================================
# Temporary Files
# ============================================================
*.tmp
*.temp
*.bak
*.orig

# ============================================================
# Database Data (don't include in image)
# ============================================================
*.db
*.sqlite
*.sqlite3
postgres-data/
pgdata/
dump.rdb
