# ============================================================
# SiroMix V2 - Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# ============================================================
# Google OAuth Configuration
# ============================================================
# Get these from: https://console.cloud.google.com/apis/credentials
# Create OAuth 2.0 Client ID (Web application)
# Authorized JavaScript origins: http://localhost:3000
# Authorized redirect URIs: http://localhost:3000/api/auth/callback/google

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================================
# NextAuth Configuration (Frontend)
# ============================================================
# NEXTAUTH_URL should match your frontend URL
NEXTAUTH_URL=http://localhost:3000

# Generate with: openssl rand -base64 32
# Or PowerShell: [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Minimum 0 -Maximum 256 }))
NEXTAUTH_SECRET=generate-a-random-secret-key-here

# ============================================================
# Backend API Configuration
# ============================================================
# URL where frontend can reach the backend API
API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ============================================================
# Database Configuration
# ============================================================
# PostgreSQL connection string
# Format: postgresql+asyncpg://user:password@host:port/database
# For Docker: host is 'db' (service name in docker-compose.yml)
# For local: host is 'localhost'

POSTGRES_USER=siromix
POSTGRES_PASSWORD=siromix_dev_password
POSTGRES_DB=siromix_v2

# Full database URL (used by backend)
DATABASE_URL=postgresql+asyncpg://siromix:siromix_dev_password@db:5432/siromix_v2

# For local development (without Docker):
# DATABASE_URL=postgresql+asyncpg://siromix:siromix_dev_password@localhost:5432/siromix_v2

# ============================================================
# Redis Configuration
# ============================================================
# Redis connection string for job queue and caching
# For Docker: host is 'redis' (service name in docker-compose.yml)
# For local: host is 'localhost'

REDIS_URL=redis://redis:6379/0

# For local development (without Docker):
# REDIS_URL=redis://localhost:6379/0

# ============================================================
# Celery Configuration
# ============================================================
# Celery broker and result backend (using Redis)

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# For local development (without Docker):
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ============================================================
# Application Configuration
# ============================================================
# Environment mode
ENVIRONMENT=development
NODE_ENV=development
DEBUG=true

# API server configuration (backend)
API_HOST=0.0.0.0
API_PORT=8000

# Frontend server configuration
PORT=3000
HOSTNAME=0.0.0.0

# ============================================================
# Optional: Feature Flags & Advanced Settings
# ============================================================
# Enable/disable telemetry
NEXT_TELEMETRY_DISABLED=1

# LOG_LEVEL=info
# CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================================
# Production Configuration (Examples - DO NOT USE IN DEV)
# ============================================================
# For production deployment, use:
# - Secure randomly generated secrets
# - Production database with strong passwords
# - HTTPS URLs (https://, not http://)
# - Restricted CORS origins
# - ENVIRONMENT=production
# - DEBUG=false

# Example production values (replace with your own):
# NEXTAUTH_URL=https://app.siromix.com
# API_BASE_URL=https://api.siromix.com
# DATABASE_URL=postgresql+asyncpg://prod_user:secure_password@prod-db.example.com:5432/siromix_prod
# REDIS_URL=redis://prod-redis.example.com:6379/0
# ENVIRONMENT=production
# DEBUG=false
